# SATHI - Accessibility Companion Agent
# Environment Variables Required for Backend Functionality

# Groq API Key - used for Vision AI (scene description) and Subtitle AI (transcript summarization)
# Get your key from: https://console.groq.com/keys
GROQ_API_KEY=gsk_your_key_here

# Fast2SMS API Key - used for SOS emergency SMS alerts
# Get your key from: https://www.fast2sms.com/
FAST2SMS_KEY=your_fast2sms_api_key_here

# Family/Guardian phone number for SOS alerts (Indian 10-digit number)
FAMILY_PHONE=9XXXXXXXXX
